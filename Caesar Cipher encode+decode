def caesar(text, shift, mode):
 result = ""
 if mode == "decode":
    shift = -shift
  for char in text:
    if char.isalpha():
     base = 65 if char.isupper() else 97
     result += chr((ord(char) - base + shift) % 26 + base)
   else:
     result += char
  return result

message = "hello"
shift = 3
mode = "encode"
print(caesar(message, shift, mode))



# expected output: khoor
