def decode(text, shift):
 result=""
 for char in text:
   if char.isalpha():
     if char,isupper():
        result += chr((ord(char)-65-shift)%26+65)
     else:
        result += chr((ord(char)-97-shift)%26+97)
   else:
     result += char
 return result


#execution code
secret_message = "Krz duh brx?"
decrypted_message = decode( secret_message, 3 )
print( decrypted_message )
