def reverse_caesar(text, shift):
    reversed_text = text[::-1]
    result = ""
    for char in reversed_text:
        if char.isalpha():
            base = 65 if char.isupper() else 97
            result += chr((ord(char) - base + shift) % 26 + base)
        else:
            result += char
    return result


message = "got you"
shift = 18
print(reverse_caesar(message, shift))




